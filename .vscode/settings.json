{
	"chat.useAgentSkills": true,
	"editor.formatOnSave": true,
	"editor.codeActionsOnSave": {
		"source.fixAll.oxc": "always"
	},
	"oxc.typeAware": true,
	"chat.tools.terminal.autoApprove": {
		"/^ls/": true,
		"/^cd/": true,
		"/^grep/": true,
		"/^cat/": true,
		"npm run format": true,
		"npm run lint": true,
		"npm run test": true,
		"npm run check": true,
		"npm run build": true,
		"npx tsc": true
	}
}
