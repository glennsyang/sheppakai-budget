{
	"name": "sheppakai-budget",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"lint": "oxlint && npm run lint:static",
		"lint:fix": "oxlint --fix",
		"lint:static": "npm run check:dead-exports && npm run check:redirect-throws && npm run check:no-explicit-any",
		"lint:github": "oxlint --format=github",
		"check:dead-exports": "node scripts/check-dead-exports.mjs",
		"check:redirect-throws": "node scripts/check-redirect-throws.mjs",
		"check:no-explicit-any": "node scripts/check-no-explicit-any.mjs",
		"test": "npm run test:unit -- --run",
		"test:unit": "vitest",
		"test:ci": "npm run test:unit -- --run && npm run test:coverage",
		"test:coverage": "vitest run --coverage",
		"check:all": "npm run fmt && npm run lint && npm run test",
		"update-deps": "npm outdated || npm update",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@sentry/sveltekit": "^10.47.0",
		"better-auth": "^1.5.4",
		"better-sqlite3": "^12.6.2",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"drizzle-kit": "^0.31.9",
		"drizzle-orm": "^0.45.1",
		"mode-watcher": "^1.1.0",
		"resend": "^6.10.0"
	},
	"devDependencies": {
		"@flydotio/dockerfile": "^0.7.10",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.7.0",
		"@sveltejs/adapter-node": "^5.4.0",
		"@sveltejs/kit": "^2.49.2",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/table-core": "^8.21.3",
		"@types/better-sqlite3": "^7.6.12",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.7",
		"@types/node": "^25.7.0",
		"@vitest/coverage-v8": "^4.0.18",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"globals": "^17.1.0",
		"knip": "^6.11.0",
		"layerchart": "^2.0.0-next.63",
		"lefthook": "^2.0.16",
		"lint-staged": "^17.0.4",
		"oxfmt": "^0.51.0",
		"oxlint": "^1.66.0",
		"oxlint-tsgolint": "^0.23.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.3.4",
		"svelte-sonner": "^1.0.7",
		"sveltekit-superforms": "^2.29.1",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.13",
		"vitest": "^4.1.6",
		"zod": "^4.4.3"
	},
	"lint-staged": {
		"*.(js|ts|svelte)": [
			"npm run fmt",
			"npm run lint"
		],
		"*.svelte": [
			"svelte-check --threshold error"
		],
		"*.(json|md|css|html|svg)": [
			"npm run fmt"
		]
	}
}
